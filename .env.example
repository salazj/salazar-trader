# $alazar-Trader Configuration
# Copy this to .env and fill in your values.

# --- Mode ---
# MUST be true for first-time use. Set false only when you understand all risks.
DRY_RUN=true
# Second safety gate: BOTH DRY_RUN=false AND ENABLE_LIVE_TRADING=true are
# required before any real order can be submitted. This is intentional.
ENABLE_LIVE_TRADING=false
# Third safety gate: explicit acknowledgement of live trading risks
LIVE_TRADING_ACKNOWLEDGED=false

# --- Exchange Selection ---
# "polymarket" or "kalshi"
EXCHANGE=polymarket

# --- Polymarket API ---
POLYMARKET_HOST=https://clob.polymarket.com
POLYMARKET_WS_HOST=wss://ws-subscriptions-clob.polymarket.com/ws
CHAIN_ID=137

# --- Polymarket Wallet ---
# Private key for signing transactions. NEVER commit this.
PRIVATE_KEY=
# Polymarket API credentials (derived via scripts/derive_api_credentials.py)
POLY_API_KEY=
POLY_API_SECRET=
POLY_PASSPHRASE=

# --- Kalshi API ---
# API key from https://kalshi.com/account/api-keys
KALSHI_API_KEY=
# Absolute path to your RSA private key file (PEM format, 4096-bit recommended)
# Generate with: openssl genrsa -out kalshi_private.pem 4096
# Upload public key: openssl rsa -in kalshi_private.pem -pubout -out kalshi_public.pem
KALSHI_PRIVATE_KEY_PATH=
# Production API endpoints (used when KALSHI_DEMO_MODE=false)
KALSHI_BASE_URL=https://trading-api.kalshi.com/trade-api/v2
KALSHI_WS_URL=wss://trading-api.kalshi.com/trade-api/ws/v2
# Set to true to use Kalshi demo/sandbox environment (recommended for testing)
# Demo endpoints: https://demo-api.kalshi.co/trade-api/v2
KALSHI_DEMO_MODE=true

# --- Risk Limits ---
MAX_POSITION_PER_MARKET=10.0
MAX_TOTAL_EXPOSURE=50.0
MAX_DAILY_LOSS=10.0
MAX_CONSECUTIVE_LOSSES=5
MAX_ORDERS_PER_MINUTE=6
MAX_SLIPPAGE=0.03
MIN_LIQUIDITY_DEPTH=20.0
MIN_SPREAD_THRESHOLD=0.01
MAX_SPREAD_THRESHOLD=0.15

# --- Strategy ---
STRATEGY=passive_market_maker
DEFAULT_ORDER_SIZE=1.0

# --- Decision Engine ---
DECISION_MODE=conservative
ENSEMBLE_WEIGHT_L1=0.30
ENSEMBLE_WEIGHT_L2=0.40
ENSEMBLE_WEIGHT_L3=0.30
MIN_ENSEMBLE_CONFIDENCE=0.60
MIN_LAYERS_AGREE=2
# Minimum total signals across all layers before a trade is considered
MIN_EVIDENCE_SIGNALS=2
# Trades with size >= this threshold require extra multi-layer alignment
LARGE_TRADE_THRESHOLD=3.0
LARGE_TRADE_MIN_LAYERS=3
# Net score below this with disagreeing layers = conflict veto
CONFLICT_TOLERANCE=0.15

# --- NLP / News ---
# Providers: mock, file, rss
NLP_PROVIDER=mock
NEWS_POLL_INTERVAL=300
NEWS_FILE_DIR=data/news

# --- LLM / AI Provider ---
# "none" = no LLM (keyword classifiers only, fully functional)
# "local_open_source" = local model via OpenAI-compatible API (e.g. vLLM, Ollama, llama.cpp)
# "hosted_api" = hosted API (e.g. OpenAI, Anthropic, Together, Groq)
LLM_PROVIDER=none
# Model name passed to the API (e.g. "meta-llama/Llama-3.1-8B-Instruct",
# "mistralai/Mistral-7B-Instruct-v0.3", "gpt-4o-mini")
LLM_MODEL_NAME=
# Base URL for the LLM API. For local models: http://localhost:8000/v1
# For hosted APIs: https://api.openai.com/v1 (or provider URL)
LLM_BASE_URL=
# API key. Leave empty for local models that don't require auth.
LLM_API_KEY=
LLM_TIMEOUT_SECONDS=30
LLM_CONFIDENCE_THRESHOLD=0.5

# --- Level 2 ML ---
# Model type: logistic_regression, gradient_boosting, random_forest
ML_MODEL_NAME=gradient_boosting

# --- Storage ---
DATABASE_URL=sqlite:///salazar-trader.db

# --- Logging ---
LOG_LEVEL=INFO

# --- Environment ---
ENVIRONMENT=development
