# =============================================================================
# Salazar-Trader — Jetson Orin Nano AI-Assisted Stock Trading Bot
# =============================================================================
# This .env is tuned for NVIDIA Jetson Orin Nano running Alpaca paper trading.
# DRY_RUN is the safest default. Live trading requires THREE explicit gates.
#
# Copy this file to `.env` and fill in your Alpaca credentials.
# =============================================================================

# --- Mode (THREE SAFETY GATES) -----------------------------------------------
# Gate 1: simulate everything locally — no real broker calls.
DRY_RUN=true
# Gate 2: enable live trading explicitly.
ENABLE_LIVE_TRADING=false
# Gate 3: explicit acknowledgement of live-trading risks.
LIVE_TRADING_ACKNOWLEDGED=false

# --- Asset Class & Broker ----------------------------------------------------
# Equities-first project — leave as `equities`.
ASSET_CLASS=equities
BROKER=alpaca

# Alpaca API — sign up at https://app.alpaca.markets/
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
# Paper trading endpoint (strongly recommended for first runs).
ALPACA_PAPER=true

# --- Stock Universe ----------------------------------------------------------
# `manual` = trade only the comma-separated tickers; `filtered` = scan + filter.
STOCK_UNIVERSE_MODE=manual
# Default tickers that the bot will subscribe to.
STOCK_TICKERS=SPY,QQQ,AAPL,MSFT,NVDA,TSLA,AMD,META,AMZN,GOOGL
# Allow-list — risk manager BLOCKS any ticker not in this set.
APPROVED_STOCK_TICKERS=SPY,QQQ,AAPL,MSFT,NVDA,TSLA,AMD,META,AMZN,GOOGL
# Filter knobs (used in `filtered` mode).
STOCK_MIN_VOLUME=100000
STOCK_MIN_PRICE=5.0
STOCK_MAX_PRICE=500.0
ALLOW_EXTENDED_HOURS=false

# --- Stock Risk Limits (BEGINNER-SAFE JETSON DEFAULTS) -----------------------
# Tiny by design. Override for larger accounts after you have validated the
# strategies on paper trading.
STOCK_MAX_POSITION_DOLLARS=50
STOCK_MAX_PORTFOLIO_DOLLARS=250
STOCK_MAX_DAILY_LOSS_DOLLARS=25
STOCK_MAX_OPEN_POSITIONS=3
STOCK_MAX_ORDERS_PER_MINUTE=3
STOCK_MAX_TRADES_PER_DAY=5
STOCK_REQUIRE_STOP_LOSS=true
STOCK_MAX_CONSECUTIVE_LOSSES_PER_SYMBOL=2
STOCK_MAX_BAR_AGE_SECONDS=120

# --- Three-Layer Decision Engine --------------------------------------------
# Final score = L1*W1 + L2*W2 + L3*W3 + bounded confidence_adjustment.
STOCK_L1_WEIGHT=0.50
STOCK_L2_WEIGHT=0.30
STOCK_L3_WEIGHT=0.20
# Trades blocked when |final_score| < this threshold.
STOCK_MIN_FINAL_SCORE=0.55

# --- Local LLM (Jetson Orin Nano) -------------------------------------------
# Choose ONE provider: none, llama_cpp, ollama
LOCAL_LLM_PROVIDER=none
# llama.cpp: path to a quantized GGUF file under ./models
LOCAL_LLM_MODEL_PATH=models/qwen2.5-3b-instruct-q4.gguf
# Ollama: model tag and HTTP endpoint
LOCAL_LLM_MODEL_NAME=qwen2.5:3b-instruct-q4_K_M
LOCAL_LLM_ENDPOINT=http://127.0.0.1:11434
# Inference settings — keep small for Jetson Orin Nano
LOCAL_LLM_CONTEXT_SIZE=2048
LOCAL_LLM_THREADS=4
LOCAL_LLM_GPU_LAYERS=20
LOCAL_LLM_TEMPERATURE=0.1
LOCAL_LLM_MAX_TOKENS=512
LOCAL_LLM_TIMEOUT_SECONDS=20
LOCAL_LLM_CACHE_TTL_SECONDS=1800

# --- Stock ML Layer ---------------------------------------------------------
STOCK_ML_MODEL_PATH=model_artifacts/stock_xgb_v1.pkl
STOCK_ML_MIN_SAMPLES=200

# --- Market Regime Detector -------------------------------------------------
REGIME_LOOKBACK_BARS=60

# --- Storage / Logging ------------------------------------------------------
DATABASE_URL=sqlite:///salazar-trader.db
LOG_LEVEL=INFO
ENVIRONMENT=development

# --- News (optional) --------------------------------------------------------
# Free RSS works without keys. Finnhub / NewsAPI need free signups.
NLP_PROVIDERS=rss
RSS_FEED_URLS=https://feeds.reuters.com/reuters/businessNews,https://www.cnbc.com/id/100003114/device/rss/rss.html
NEWSAPI_KEY=
FINNHUB_API_KEY=
NEWS_POLL_INTERVAL=300
